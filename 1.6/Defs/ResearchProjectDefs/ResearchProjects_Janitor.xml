<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!--
    Sanitation — umbrella research for the mod's work wear and cleaning gear.
    Prereqs ComplexClothing so it sits in the same neighbourhood as other industrial
    work uniforms. Future janitorial content (signage, advanced gear, supply carts)
    should slot under this research rather than spawning new research projects.
  -->
  <ResearchProjectDef>
    <defName>Sanitation</defName>
    <label>sanitation</label>
    <description>Practices and gear for keeping a settlement clean. Boots that grip wet floors, gloves that handle solvents, and coveralls with pockets deep enough to lose a wrench in.</description>
    <baseCost>500</baseCost>
    <techLevel>Industrial</techLevel>
    <prerequisites>
      <li>ComplexClothing</li>
    </prerequisites>
    <researchViewX>4.00</researchViewX>
    <researchViewY>1.20</researchViewY>
    <tab>Main</tab>
  </ResearchProjectDef>

</Defs>
