<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- Without these overrides, PE maps Industrial-tier weapons to Firearm proficiency. -->

  <Operation Class="PatchOperationAddModExtension" MayRequire="ferny.ProgressionEducation">
    <xpath>Defs/ThingDef[defName="Janitor_PushBroom"]</xpath>
    <value>
      <li Class="ProgressionEducation.ItemProficiencyRequirement">
        <requiredProficiency>PE_LowTechProficiency</requiredProficiency>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAddModExtension" MayRequire="ferny.ProgressionEducation">
    <xpath>Defs/ThingDef[defName="Janitor_Mop"]</xpath>
    <value>
      <li Class="ProgressionEducation.ItemProficiencyRequirement">
        <requiredProficiency>PE_LowTechProficiency</requiredProficiency>
      </li>
    </value>
  </Operation>

</Patch>
