<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!--
    Register the cleaning-tool StatPart on vanilla CleaningSpeed. The StatPart subtracts a
    tool's equipped CleaningSpeed offset back out when the filth currently being cleaned
    doesn't fall into one of the tool's declared categories — a bonus-only specialty system,
    never punitive vs. vanilla baseline.

    Wet/dry classification of each FilthDef is inferred at runtime from its cleaningSound
    (vanilla flags wet filth with Interact_CleanFilth_Fluid and dry with the Dirt variant),
    so we don't need to enumerate every vanilla/DLC/modded filth here. If a specific filth's
    sound is misleading, attach a JanitorsCloset.Cleaning.FilthCategoryExtension to its def
    as an override.
  -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StatDef[defName="CleaningSpeed"]</xpath>
    <value>
      <parts>
        <li Class="JanitorsCloset.Cleaning.StatPart_CleaningToolMatch"/>
        <li Class="JanitorsCloset.Cleaning.StatPart_AreaCleanerSilentSpeed"/>
      </parts>
    </value>
  </Operation>

  <!--
    Register the pollution-tool StatPart on GeneralLaborSpeed. JobDriver_ClearPollution
    (Biotech's "clear pollution" work) scales per-tick progress by GeneralLaborSpeed * delta,
    so that's the stat we have to ride to make a tool meaningfully faster at pollution work.
    The StatPart only adds during an active pollution job for the pawn — every other use of
    GeneralLaborSpeed (cooking, smithing, hauling speed factors that read it) is untouched.
  -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StatDef[defName="GeneralLaborSpeed"]</xpath>
    <value>
      <parts>
        <li Class="JanitorsCloset.Cleaning.StatPart_PollutionToolBonus"/>
      </parts>
    </value>
  </Operation>

</Patch>
