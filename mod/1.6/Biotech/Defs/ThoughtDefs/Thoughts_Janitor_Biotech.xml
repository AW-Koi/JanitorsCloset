<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- Biotech-only: refreshed while a bystander stands within the Hazmat Sprayer's
         spray cone. Worse than the mop splash because it's industrial decon foam, not
         water. -->
    <ThoughtDef>
        <defName>Janitor_DousedInDeconFoam</defName>
        <durationDays>0.3</durationDays>
        <stackLimit>1</stackLimit>
        <stages>
            <li>
                <label>doused in decontaminant</label>
                <description>I caught a faceful of industrial decontaminant foam. It stings.</description>
                <baseMoodEffect>-3</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>

    <!-- Social counterpart to Janitor_DousedInDeconFoam: targeted at the sprayer.
         Stronger and longer-lived than the mop equivalent — industrial decon foam in
         the face is harder to forgive than a stray water flick. -->
    <ThoughtDef>
        <defName>Janitor_AnnoyedByDeconFoam</defName>
        <thoughtClass>Thought_MemorySocial</thoughtClass>
        <durationDays>0.3</durationDays>
        <stackLimit>1</stackLimit>
        <stages>
            <li>
                <label>sprayed me with decontaminant</label>
                <baseOpinionOffset>-5</baseOpinionOffset>
            </li>
        </stages>
    </ThoughtDef>

</Defs>
