<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- The Straw Broom — neolithic tier, dry filth only. Cheap, light, and useless against anything wet. -->
  <ThingDef ParentName="BaseMeleeWeapon_Blunt_Quality">
    <defName>Janitor_StrawBroom</defName>
    <label>straw broom</label>
    <description>A bundle of dried straw lashed to a wooden handle. Pushes dust and grit around with admirable enthusiasm. Hopeless against anything wet; the straw just smears the mess around.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/Janitor_StrawBroom</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>Cutout</shaderType>
      <drawSize>(1.25, 0.625)</drawSize>
    </graphicData>
    <uiIconScale>1.1</uiIconScale>
    <techLevel>Neolithic</techLevel>
    <weaponClasses>
      <li>MeleeBlunt</li>
    </weaponClasses>
    <costList>
      <WoodLog>20</WoodLog>
      <Hay>5</Hay>
    </costList>
    <statBases>
      <WorkToMake>800</WorkToMake>
      <Mass>1.2</Mass>
    </statBases>
    <equippedStatOffsets>
      <CleaningSpeed>0.15</CleaningSpeed>
    </equippedStatOffsets>
    <equippedAngleOffset>350</equippedAngleOffset>
    <modExtensions>
      <li Class="JanitorsCloset.Cleaning.CleaningToolExtension">
        <categories>
          <li>Dry</li>
        </categories>
        <animProfile>
          <basePhaseRate>0.075</basePhaseRate>
          <speedModRate>0.025</speedModRate>
          <speedModDepth>1.0</speedModDepth>
          <wobbleDegrees>18</wobbleDegrees>
          <slideTiles>0.10</slideTiles>
          <reachFactor>0.25</reachFactor>
          <rotationOffset>25</rotationOffset>
          <verticalOffset>0.25</verticalOffset>
        </animProfile>
      </li>
    </modExtensions>
    <recipeMaker>
      <researchPrerequisite>Housekeeping</researchPrerequisite>
      <recipeUsers>
        <li>CraftingSpot</li>
      </recipeUsers>
      <displayPriority>240</displayPriority>
    </recipeMaker>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>4</power>
        <cooldownTime>1.8</cooldownTime>
      </li>
      <li>
        <label>bristles</label>
        <labelUsedInLogging>false</labelUsedInLogging>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>4</power>
        <cooldownTime>2.0</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <!-- The Push Broom — industrial-tier dry-filth specialist. Wider sweep than a straw broom,
       cleaner stroke, no water involved. The dry-floor counterpart to the mop. -->
  <ThingDef ParentName="BaseMeleeWeapon_Blunt_Quality">
    <defName>Janitor_PushBroom</defName>
    <label>push broom</label>
    <description>A wide block of stiff bristles bolted to a long shaft. Designed to be pushed, not waved. Sweeps a corridor's worth of grit in one pass. Not very effective for cleaning liquids, unless you want to push them around.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/Janitor_PushBroom</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(1.2, 0.6)</drawSize>
    </graphicData>
    <uiIconScale>1.1</uiIconScale>
    <techLevel>Industrial</techLevel>
    <weaponClasses>
      <li>MeleeBlunt</li>
    </weaponClasses>
    <costStuffCount>25</costStuffCount>
    <stuffCategories>
      <li>Woody</li>
      <li>Metallic</li>
    </stuffCategories>
    <costList>
      <Cloth>10</Cloth>
    </costList>
    <statBases>
      <WorkToMake>1200</WorkToMake>
      <Mass>1.4</Mass>
    </statBases>
    <equippedStatOffsets>
      <CleaningSpeed>0.25</CleaningSpeed>
    </equippedStatOffsets>
    <equippedAngleOffset>350</equippedAngleOffset>
    <modExtensions>
      <li Class="JanitorsCloset.Cleaning.CleaningToolExtension">
        <categories>
          <li>Dry</li>
        </categories>
        <animProfile>
          <basePhaseRate>0.045</basePhaseRate>
          <speedModRate>0.020</speedModRate>
          <speedModDepth>1.0</speedModDepth>
          <wobbleDegrees>8</wobbleDegrees>
          <slideTiles>0.22</slideTiles>
          <reachFactor>0.35</reachFactor>
          <rotationOffset>10</rotationOffset>
          <verticalOffset>0.15</verticalOffset>
        </animProfile>
      </li>
    </modExtensions>
    <recipeMaker>
      <researchPrerequisite>Sanitation</researchPrerequisite>
      <recipeUsers>
        <li>CraftingSpot</li>
        <li>TableMachining</li>
      </recipeUsers>
      <displayPriority>245</displayPriority>
    </recipeMaker>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>5</power>
        <cooldownTime>1.8</cooldownTime>
      </li>
      <li>
        <label>brush block</label>
        <labelUsedInLogging>false</labelUsedInLogging>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2.0</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <!-- The Mop — a janitor's primary tool, but works in a pinch as a blunt instrument. -->
  <ThingDef ParentName="BaseMeleeWeapon_Blunt_Quality">
    <defName>Janitor_Mop</defName>
    <label>mop</label>
    <description>A long wooden handle with a fistful of absorbent fibres at one end. Indispensable for cleaning floors, and surprisingly serviceable for bonking raiders. Swing the dirty end at the problem.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/Janitor_Mop</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(1.25, 0.35)</drawSize>
    </graphicData>
    <uiIconScale>1.1</uiIconScale>
    <techLevel>Industrial</techLevel>
    <weaponClasses>
      <li>MeleeBlunt</li>
    </weaponClasses>
    <costStuffCount>30</costStuffCount>
    <stuffCategories>
      <li>Woody</li>
      <li>Metallic</li>
    </stuffCategories>
    <costList>
      <Cloth>15</Cloth>
    </costList>
    <statBases>
      <WorkToMake>1500</WorkToMake>
      <Mass>1.5</Mass>
    </statBases>
    <equippedStatOffsets>
      <CleaningSpeed>0.3</CleaningSpeed>
    </equippedStatOffsets>
    <equippedAngleOffset>170</equippedAngleOffset>
    <modExtensions>
      <li Class="JanitorsCloset.Cleaning.CleaningToolExtension">
        <categories>
          <li>Wet</li>
        </categories>
        <animProfile>
          <basePhaseRate>0.025</basePhaseRate>
          <speedModRate>0.025</speedModRate>
          <speedModDepth>3</speedModDepth>
          <wobbleDegrees>20</wobbleDegrees>
          <slideTiles>0.125</slideTiles>
          <reachFactor>0.3</reachFactor>
          <rotationOffset>30</rotationOffset>
          <verticalOffset>0.3</verticalOffset>
        </animProfile>
      </li>
    </modExtensions>
    <recipeMaker>
      <researchPrerequisite>Sanitation</researchPrerequisite>
      <recipeUsers>
        <li>CraftingSpot</li>
        <li>TableMachining</li>
      </recipeUsers>
      <displayPriority>250</displayPriority>
    </recipeMaker>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>5</power>
        <cooldownTime>1.8</cooldownTime>
      </li>
      <li>
        <label>head</label>
        <labelUsedInLogging>false</labelUsedInLogging>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>7</power>
        <cooldownTime>2.0</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <!-- The Glittervacuum — spacer-tier universal cleaner. Decouples filth from local reality. -->
  <ThingDef ParentName="BaseMeleeWeapon_Blunt_Quality">
    <defName>Janitor_Glittervacuum</defName>
    <label>glittervacuum</label>
    <description>Despite the name, it doesn't suck. A glitterworld field projector that quietly unmakes filth where it sits. 'Vacuum' stuck because 'reality-uncoupler' wouldn't fit on the label.</description>
    <graphicData>
      <texPath>Things/Item/Equipment/Janitor_Glittervacuum</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>Cutout</shaderType>
      <drawSize>(1.25, 0.45)</drawSize>
    </graphicData>
    <uiIconScale>1.1</uiIconScale>
    <techLevel>Spacer</techLevel>
    <weaponClasses>
      <li>MeleeBlunt</li>
    </weaponClasses>
    <costList>
      <Plasteel>40</Plasteel>
      <ComponentSpacer>1</ComponentSpacer>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <statBases>
      <WorkToMake>16000</WorkToMake>
      <Mass>1.0</Mass>
    </statBases>
    <equippedStatOffsets>
      <CleaningSpeed>1.0</CleaningSpeed>
    </equippedStatOffsets>
    <equippedAngleOffset>0</equippedAngleOffset>
    <modExtensions>
      <li Class="JanitorsCloset.Cleaning.CleaningToolExtension">
        <categories>
          <li>Dry</li>
          <li>Wet</li>
        </categories>
        <customCleaningSound>Janitor_Glittervacuum_Cleaning</customCleaningSound>
        <animProfile>
          <basePhaseRate>0.035</basePhaseRate>
          <speedModRate>0.015</speedModRate>
          <speedModDepth>1.0</speedModDepth>
          <wobbleDegrees>12</wobbleDegrees>
          <slideTiles>0.08</slideTiles>
          <reachFactor>0.25</reachFactor>
          <rotationOffset>0</rotationOffset>
          <verticalOffset>0</verticalOffset>
          <aimAtTarget>true</aimAtTarget>
        </animProfile>
      </li>
    </modExtensions>
    <recipeMaker>
      <researchPrerequisite>AtomicSanitation</researchPrerequisite>
      <recipeUsers>
        <li>FabricationBench</li>
      </recipeUsers>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>260</displayPriority>
    </recipeMaker>
    <tools>
      <li>
        <label>emitter</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>6</power>
        <cooldownTime>1.6</cooldownTime>
      </li>
      <li>
        <label>field discharge</label>
        <labelUsedInLogging>false</labelUsedInLogging>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>1</power>
        <cooldownTime>2.0</cooldownTime>
        <extraMeleeDamages>
          <li>
            <def>Burn</def>
            <amount>5</amount>
          </li>
        </extraMeleeDamages>
      </li>
    </tools>
  </ThingDef>

</Defs>
