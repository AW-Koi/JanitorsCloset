<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!--
    Janitor_MopMark — the "damp floor" trace left when a mop-equipped janitor cleans a tile.
    Inherits BaseFilth, so we get vanilla puddle rendering (Things/Filth/PoolSoft), the
    fluid cleaning sound, MapMesh-flat tile-aligned drawing, and the timed disappearance
    machinery for free.

    Design intent:
      * Distinct defName from Filth_Water — lets future systems (slip mechanics, wet-floor-
        sign WorkGiver) target *only* mop marks without false-matching rain spatter.
      * Visibly short-lived — fades on its own as a "the janitor was just here" cue, not a
        chore for the next cleaner.
      * Not meant to be cleaned by other pawns. v0.2 ships a Harmony prefix on
        WorkGiver_CleanFilth that excludes this def from cleaning-job scans. The very
        short lifetime here is defence-in-depth, NOT the actual enforcement.
      * Nothing spawns Janitor_MopMark in v0.1 — the def is wired up in v0.2 alongside
        the cleaning-job hook and wet-floor-sign WorkGiver. Defining it now keeps that
        change purely additive on the C# side.
  -->
  <!--
    Janitor_HazmatFoam — the white decontaminant foam deposited by the Hazmat Sprayer.
    Visible at every zoom level because it's a real Filth thing rendered through the
    terrain layer, not a transient mote that LOD-culls when small on screen. This is what
    actually sells "the janitor is working here" from across the map.

    Mechanically a marker, not a chore:
      * Excluded from the cleaning work queue by Patch_SkipCleaningMopMark (same skip
        list as the mop's damp-floor mark).
      * Negligible cleanliness/beauty penalty so it doesn't tank a room's stats just
        because a cleanup pass passed through.
      * Reuses vanilla Things/Filth/FireFoam art with a low-alpha tint so we don't
        ship texture assets; the texture is already a clean "foamy spread on floor."
      * Decays in hours, not days — long enough to read at distance while the work
        happens, short enough that the colony isn't permanently foam-marked.
  -->
  <ThingDef ParentName="BaseFilth">
    <defName>Janitor_HazmatFoam</defName>
    <label>decontaminant foam</label>
    <description>A patch of pale neutraliser foam sprayed across the floor. Breaks down a few hours after application.</description>
    <statBases>
      <Beauty>-1</Beauty>
      <Cleanliness>0</Cleanliness>
    </statBases>
    <graphicData>
      <texPath>Things/Filth/FireFoam</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <!-- Low-alpha white so the foam reads as a soft deposit, not a thick fire-foam
           splat. The FireFoam texture is already near-white; the alpha is what gates
           opacity. -->
      <color>(1, 1, 1, 0.55)</color>
      <drawSize>1.75</drawSize>
    </graphicData>
    <filth>
      <!-- Couple of in-game hours. Long enough to mark a whole work session, short
           enough that the foam isn't a permanent floor decoration. -->
      <disappearsInDays>0.08~0.12</disappearsInDays>
      <ignoreFilthMultiplierStat>true</ignoreFilthMultiplierStat>
      <canFilthAttach>false</canFilthAttach>
      <allowsFire>false</allowsFire>
      <rainWashes>true</rainWashes>
      <!-- High work-to-clean number because cleaning never actually runs on this def —
           the skip patch keeps it out of the queue. The number is just defensive in
           case some other mod queues it directly. -->
      <cleaningWorkToReduceThickness>9999</cleaningWorkToReduceThickness>
    </filth>
  </ThingDef>

  <ThingDef ParentName="BaseFilth">
    <defName>Janitor_MopMark</defName>
    <label>damp floor</label>
    <description>A patch of floor still damp from a recent mopping. It will dry on its own shortly.</description>
    <statBases>
      <Beauty>0</Beauty>
      <Cleanliness>0</Cleanliness>
    </statBases>
    <graphicData>
      <texPath>Things/Filth/PoolSoft</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <color>(120, 146, 185, 140)</color>
      <drawSize>2</drawSize>
    </graphicData>
    <filth>
      <disappearsInDays>0.02~0.03</disappearsInDays>
      <cleaningWorkToReduceThickness>30</cleaningWorkToReduceThickness>
      <canFilthAttach>false</canFilthAttach>
      <allowsFire>false</allowsFire>
      <cleaningSound>Interact_CleanFilth_Fluid</cleaningSound>
    </filth>
  </ThingDef>

</Defs>
