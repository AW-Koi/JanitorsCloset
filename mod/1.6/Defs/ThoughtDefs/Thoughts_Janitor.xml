<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- Memory granted (and refreshed) while a colonist is in a room that was recently
         cleaned to zero filth. stackLimit=1 so repeated TryGainMemory calls refresh the
         existing memory's age instead of stacking new instances. -->
    <ThoughtDef>
        <defName>Janitor_FreshlyCleanedRoom</defName>
        <durationDays>0.17</durationDays>
        <stackLimit>1</stackLimit>
        <stages>
            <li>
                <label>freshly cleaned room</label>
                <description>That room was spotless. I'm glad we have a janitor around.</description>
                <baseMoodEffect>3</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>

    <!-- Refreshed every mop-mark spawn while a bystander is adjacent to the mopper. -->
    <ThoughtDef>
        <defName>Janitor_SplashedByMop</defName>
        <durationDays>0.04</durationDays>
        <stackLimit>1</stackLimit>
        <stages>
            <li>
                <label>splashed by the mop</label>
                <description>I got mop water flicked on me. Eww.</description>
                <baseMoodEffect>-1</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>

    <!-- Social counterpart to Janitor_SplashedByMop: targeted at the mopper so the
         bystander's opinion of them dips slightly. Same refresh cadence as the mood
         memory so the two age out together. -->
    <ThoughtDef>
        <defName>Janitor_AnnoyedByMopSplash</defName>
        <thoughtClass>Thought_MemorySocial</thoughtClass>
        <durationDays>0.04</durationDays>
        <stackLimit>1</stackLimit>
        <stages>
            <li>
                <label>splashed me with the mop</label>
                <baseOpinionOffset>-3</baseOpinionOffset>
            </li>
        </stages>
    </ThoughtDef>

    <!-- One-shot, granted when a pawn deposits filth in a room we'd just stamped clean.
         Vanilla pawn-tracked filth (mud, blood) is the main trigger. -->
    <ThoughtDef>
        <defName>Janitor_TrackedFilthIntoCleanRoom</defName>
        <durationDays>0.08</durationDays>
        <stackLimit>1</stackLimit>
        <stages>
            <li>
                <label>tracked filth into a clean room</label>
                <description>I just trampled mess into a freshly cleaned room. Oops.</description>
                <baseMoodEffect>-2</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>

</Defs>
